meta {
  name: Update phone number
  type: http
  seq: 1
}

put {
  url: {{ProfileBaseAddress}}/api/v1/users/current/notificationsettings/private/phonenumber
  body: json
  auth: inherit
}

body:json {
  {
    "value": null
  }
}

docs {
  Sets the phone number for an si user. Remember to add the bearer token for the SI user as this request is not 
  currently set up with script for bearer token. 
}
