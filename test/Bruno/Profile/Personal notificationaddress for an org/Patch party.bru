}

patch {
  url: {{ProfileBaseAddress}}/api/v1/users/current/notificationsettings/parties/{{Party_PartyUuid}}
  body: json
  auth: inherit
}

body:json {
  {
    "emailAddress": "nullstilt@altinn.xyz",
    "phoneNumber": "+4799999999",
    "resourceIncludeList": [
      "urn:altinn:resource:app_ttd_storage-end-to-end"
    ]
  }
}

script:pre-request {
  await bru.runRequest("TokenGenerator/portal user")
}

docs {
  Update some of the settings for the user
}
